# Contentful — Space ID and Delivery API token from contentful.com
VITE_CONTENTFUL_SPACE_ID=your_space_id_here
VITE_CONTENTFUL_ACCESS_TOKEN=your_delivery_api_token_here

# Neon — Project Dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Auth — any long random string (rotating this logs out all users)
JWT_SECRET=a_long_random_secret_string_here

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — from `stripe listen` (dev) or dashboard (prod)
STRIPE_WEBHOOK_SECRET=whsec_...
# Comma-separated list of valid Stripe Price IDs the server will accept
STRIPE_ALLOWED_PRICE_IDS=price_abc123,price_def456
