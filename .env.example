# Contentful — Space ID and Delivery API token from contentful.com
VITE_CONTENTFUL_SPACE_ID=your_space_id_here
VITE_CONTENTFUL_ACCESS_TOKEN=your_delivery_api_token_here

# Neon — Project Dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Auth — any long random string (rotating this logs out all users)
JWT_SECRET=a_long_random_secret_string_here

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — from `stripe listen` (dev) or dashboard (prod)
STRIPE_WEBHOOK_SECRET=whsec_...
# Comma-separated list of Stripe Price IDs allowed through checkout (membership prices)
STRIPE_ALLOWED_PRICE_IDS=price_abc123,price_def456

# Vercel Blob — Vercel dashboard → Storage → Blob → Token (read/write)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# App origin — used for Stripe checkout redirect URLs.
# In dev, set to the Vite dev server URL (not the Express API port).
# On Vercel this is not needed — the forwarded host headers are correct.
APP_ORIGIN=http://localhost:5173

# Resend — resend.com → API Keys. Used for verification and purchase confirmation emails.
# From address: noreply@jxsen.com (jxsen.com is the verified domain in Resend)
RESEND_API_KEY=re_...

# Downloads — per-type default prices are defined in src/utils/format.ts (releasePrice).
# Override per-release via Contentful price/memberPrice fields (Integer, cents).
